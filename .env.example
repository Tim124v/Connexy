# Backend env
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# База данных
# Локально (SQLite): DATABASE_URL="file:./dev.db"
# Для Postgres замените на:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public
DATABASE_URL="file:./dev.db"

# (Необязательно) Redis для очередей/кэша, если понадобится
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# URL фронтенда для ссылок-приглашений (в проде подставьте прод-домен)
FRONTEND_URL=http://localhost:3000

# SMTP для отправки приглашений (можно оставить пустым, тогда письма не уйдут)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM="Chat <your-email@example.com>"

# Next.js фронтенд (в проде подставьте прод-бэкенд)
NEXT_PUBLIC_API_URL=http://localhost:3001

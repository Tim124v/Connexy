NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# Postgres (локально: Docker или облако, например Neon)
# DATABASE_URL=postgresql://user:password@localhost:5432/connexy
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/connexy

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# URL фронтенда (используется в ссылках-приглашениях)
FRONTEND_URL=http://localhost:3000

# SMTP (для отправки приглашений; можно оставить пустым чтобы отключить)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM="Chat <your-email@example.com>"
